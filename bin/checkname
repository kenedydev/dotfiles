#!/usr/bin/env python3
"""Report or normalize file and directory names to lowercase snake_case.

The convention:
  name        [a-z0-9] words joined by "_". Accents fold to their base letter,
              every other invalid character becomes a separator.
  extension   ASCII letters and digits only, lowercased. A suffix that needs any
              other change is not an extension, and is normalized as part of the
              name rather than repaired.
"""
import argparse
import re
import sys
import unicodedata
from pathlib import Path

# Renaming these breaks the tools that look them up by this exact case.
STANDARD_NAMES = {
    "CMakeLists.txt",
    "LICENSE",
    "README",
    "README.md",
    "Dockerfile",
    "docker-compose.yml",
    "Makefile",
}

# Extensions that a plain suffix search cannot find, as it stops at the last dot
# and would leave the ".tar" behind.
COMPOUND_EXTENSIONS = (".tar.gz", ".tar.xz", ".tar.bz2", ".tar.zst", ".tar.lz")

SEPARATOR = "_"
PATTERN_INVALID_CHARACTERS = r"[^a-z0-9]+"
PATTERN_EXTENSION = r"^[a-zA-Z0-9]+$"

SCRIPT_NAME = Path(__file__).name


def split_name(path):
    """Split a name into (prefix, stem, extension).

    The prefix is "." for hidden entries. Directories have no extension, and a
    suffix is only an extension if it matches PATTERN_EXTENSION.
    """
    prefix = "." if path.name.startswith(".") else ""
    # Trailing dots go first, or the search below finds the empty segment after
    # the last dot instead of the real extension.
    name = path.name[len(prefix) :].rstrip(".")

    if not path.is_file():
        return prefix, name, ""

    lowered = name.lower()
    for extension in COMPOUND_EXTENSIONS:
        if lowered.endswith(extension) and len(lowered) > len(extension):
            return prefix, name[: -len(extension)], name[-len(extension) :]

    stem, dot, extension = name.rpartition(".")
    if stem and re.match(PATTERN_EXTENSION, extension):
        return prefix, stem, dot + extension
    return prefix, name, ""


def normalize_string(string):
    """Fold accents, lowercase, and collapse each run of invalid characters into
    a single separator.

    Only the combining marks are dropped. A character with no ASCII form of its
    own (Ω, ß, kanji) stays in and becomes a separator, as dropping it would
    join its neighbours instead.
    """
    decomposed = unicodedata.normalize("NFD", string)
    unaccented = "".join(char for char in decomposed if not unicodedata.combining(char))
    normalized = re.sub(PATTERN_INVALID_CHARACTERS, SEPARATOR, unaccented.lower())
    return normalized.strip(SEPARATOR)


def target_name(path):
    """The name this path should have, or "" if nothing would be left of it."""
    prefix, stem, extension = split_name(path)
    stem = normalize_string(stem)
    return prefix + stem + extension.lower() if stem else ""


def is_valid_name(path):
    """A name is valid when normalizing it would change nothing.

    Validity is derived from the normalizer instead of being restated as a rule
    of its own, so the two cannot disagree and flag a name that cannot be fixed.
    """
    return path.name in STANDARD_NAMES or target_name(path) == path.name


def normalize_name(path, args):
    """Rename a path to its normalized name, skipping anything ambiguous."""
    new_name = target_name(path)
    if not new_name:
        print(f"{SCRIPT_NAME}: skipping (name becomes empty): {path}")
        return

    new_path = path.parent / new_name
    if new_path == path:
        return

    if args.dry_run:
        print(f"{SCRIPT_NAME}: dry run: {path} -> {new_path}")
        return

    if new_path.exists():
        print(f"{SCRIPT_NAME}: error: {new_path} already exists, skipping")
        return

    try:
        path.rename(new_path)
        if args.verbose:
            print(f"{SCRIPT_NAME}: renamed: {path} -> {new_path}")
    except OSError as error:
        print(f"{SCRIPT_NAME}: error renaming {path}: {error}")


def main():
    parser = argparse.ArgumentParser(
        prog=SCRIPT_NAME,
        description="Report or normalize file and directory names to lowercase "
        "snake_case. Without -n it only lists the names that do not match.",
    )
    parser.add_argument("paths", nargs="+", type=Path, help="files or directories to check")
    parser.add_argument(
        "-n", "--normalize-name", dest="normalize", action="store_true", help="rename instead of only reporting"
    )
    parser.add_argument("-d", "--dry-run", action="store_true", help="with -n, show renames without applying them")
    parser.add_argument("-v", "--verbose", action="store_true", help="print each rename as it happens")
    # Intermixed, so a flag is accepted anywhere among the paths.
    args = parser.parse_intermixed_args()

    for missing in (path for path in args.paths if not path.exists()):
        print(f"{SCRIPT_NAME}: error: path does not exist: {missing}")

    paths = [path for path in args.paths if path.exists()]
    if not paths:
        sys.exit(1)

    # Deepest first, so renaming a directory never invalidates a path still
    # queued below it.
    paths.sort(key=lambda path: len(path.absolute().parts), reverse=True)

    for path in paths:
        if is_valid_name(path):
            continue
        if args.normalize:
            normalize_name(path, args)
        else:
            print(path)


if __name__ == "__main__":
    main()
